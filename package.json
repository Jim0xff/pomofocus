{
  "name": "pomofocus-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest --runInBand",
    "worker:timer": "ts-node-dev --transpile-only src/workers/timerWorker.ts",
    "stats:drain": "ts-node-dev --transpile-only src/jobs/drainStatsQueue.ts",
    "guardian:timer": "ts-node-dev --transpile-only src/jobs/timerGuardian.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@apollo/server-plugin-landing-page-graphql-playground": "^4.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "bullmq": "^5.62.1",
    "cls-rtracer": "^2.6.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "graphql-type-json": "^0.3.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
